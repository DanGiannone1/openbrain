# Cosmos DB
COSMOS_HOST=https://your-cosmos-account.documents.azure.com:443/
COSMOS_KEY=your-cosmos-primary-key
COSMOS_DATABASE=openbrain
COSMOS_CONTAINER=openbrain-data

# Azure AI Foundry
AI_FOUNDRY_ENDPOINT=https://your-resource.services.ai.azure.com/
AI_FOUNDRY_API_KEY=your-api-key
AI_FOUNDRY_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# Auth
DISABLE_AUTH=true
DEFAULT_USER_ID=dev-user

# Server
ENVIRONMENT=dev
LOG_LEVEL=INFO
PORT=8000

# Infrastructure (deployment scripts only)
RESOURCE_GROUP=rg-openbrain-dev
RESOURCE_GROUP_SHARED=rg-ai-shared
ACR_NAME=youracrname
ACR_SERVER=youracrname.azurecr.io
CONTAINER_APP_ENV=openbrain-env
MCP_APP_NAME=openbrain-mcp
IMAGE_PREFIX=openbrain
